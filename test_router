from langgraph.checkpoint.memory import InMemorySaver
from RAG import search as rag_search

# ── 工具：搜索文档（和 PDFLearningAssitant 里一样） ──
@tool
def search_document(query: str) -> str:
    """在已加载的 PDF 文档中搜索相关内容。当用户询问文档中的知识时，用这个工具检索。"""
    docs = rag_search(query, strategy="mqe", k=4)
    if not docs:
        return "未在文档中找到相关内容。"
    return "\n\n---\n".join(
        f"[来源页 {doc.metadata.get('page', '?')}]\n{doc.page_content}"
        for doc in docs
    )

