    )

    # ── 打印中间步骤（看 Agent 调了哪个工具） ──
    for i, msg in enumerate(result["messages"]):
        role = getattr(msg, "type", "unknown")
        if role == "tool":
            print(f"[调用了工具] {msg.name}")
